{
	"name": "@md-schema/odr",
	"version": "1.0.0",
	"description": "",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/_module.js",
			"types": "./dist/_module.d.ts"
		},
		"./v1/architecture-decision-record": {
			"import": "./dist/v1/architecture-decision-record.js",
			"types": "./dist/v1/architecture-decision-record.d.ts"
		}
	},
	"scripts": {
		"build": "tsup-node",
		"remark:lint": "remark doc/odr/**/*.md --output",
